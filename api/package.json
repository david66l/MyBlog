{
  "name": "louis-dev-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "db:setup": "prisma db push && tsx prisma/seed.ts",
    "test:markdown": "tsx src/lib/markdown-import.test.ts",
    "test:smoke": "tsx scripts/smoke-admin.ts"
  },
  "dependencies": {
    "@fastify/cors": "^11.0.1",
    "@fastify/jwt": "^9.1.0",
    "@prisma/client": "^6.9.0",
    "bcryptjs": "^3.0.2",
    "fastify": "^5.3.3",
    "geoip-lite": "^1.4.10",
    "ip2region": "^2.3.0",
    "ua-parser-js": "^2.0.3",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/geoip-lite": "^1.4.4",
    "@types/node": "^20",
    "prisma": "^6.9.0",
    "tsx": "^4.20.3",
    "typescript": "^5"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}
